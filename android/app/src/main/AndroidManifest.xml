<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Self-update check against GitHub Releases — independent of the
         kernel OOT-modules zip release cadence, see update_checker.dart. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:label="Picters Modules Manager"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <!-- No LAUNCHER category on purpose: this app has no home-screen/app-drawer
                 icon. It is opened only via an explicit intent — the KernelSU/Magisk
                 module's Action button runs `am start -n com.picters.modulesmanager/.MainActivity`. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
            </intent-filter>
        </activity>

        <!-- Root command broker. libsu launches this in a dedicated root process
             via RootService.bind (NOT ServiceManager.addService — see
             KernelRootService). Not exported: only this app binds it. -->
        <service
            android:name=".KernelRootService"
            android:exported="false"
            android:directBootAware="true"
            tools:ignore="Instantiatable" />

        <!-- Shares the collected debug-log archive (Settings ▸ Debug) with other
             apps and the SAF save dialog via a content:// URI. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- So getLaunchIntentForPackage() can find the root manager to open on
             the "Grant root" screen (Android 11+ package-visibility rules). -->
        <package android:name="me.weishu.kernelsu"/>
        <package android:name="me.bmax.apatch"/>
        <package android:name="com.topjohnwu.magisk"/>
    </queries>
</manifest>
