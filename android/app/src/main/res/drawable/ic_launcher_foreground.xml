<?xml version="1.0" encoding="utf-8"?>
<!-- A toggle-switch glyph (pill track + knob) — the whole app is per-module
     insmod/rmmod toggles, so this is the one shape that says what it does.
     Both paths stay inside the 66dp adaptive-icon safe zone centered at 54,54. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- pill track -->
    <path
        android:pathData="M39,39 L69,39 A15,15 0 0 1 69,69 L39,69 A15,15 0 0 1 39,39 Z"
        android:fillColor="#FFFFFF" />
    <!-- knob, punched through in the background color -->
    <path
        android:pathData="M58,54 A11,11 0 1 1 80,54 A11,11 0 1 1 58,54 Z"
        android:fillColor="#6750A4" />
</vector>
